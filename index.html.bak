<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>same Path — Connect with Top Advisors</title>
  <link rel="stylesheet" href="styles.css?v=14">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>


  <!-- Navbar -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">
        <svg viewBox="0 0 24 24" style="width: 22px; height: 22px; display: inline-block; vertical-align: middle; margin-right: 6px;" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 16h8a4 4 0 0 0 4-4V4" stroke="#112F20" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3 20h9a4 4 0 0 0 4-4V7" stroke="#d97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        same Path
      </div>
      <!-- Public Navigation Links -->
      <ul class="nav-links public-nav-links">
        <li><a href="#" class="nav-link active" data-target="home">Home</a></li>
        <li><a href="#" class="nav-link" data-target="mission">Our Mission</a></li>
        <li><a href="#" class="nav-link" data-target="stories">Success Stories</a></li>
        <li><a href="#" class="nav-link" data-target="application">Advisor Application</a></li>
      </ul>
      <!-- Logged-in Portal Navigation Links -->
      <ul class="nav-links portal-nav-links" style="display: none;">
        <li><a href="#" class="nav-link active" data-target="dashboard" id="nav-link-dashboard">Expat Hub</a></li>
        <li><a href="#" class="nav-link" data-target="directory" id="nav-link-directory">Browse Guides</a></li>
        <li><a href="#" class="nav-link" data-target="advisor-portal" id="nav-link-advisor-portal" style="display: none;">Guide Workspace</a></li>
      </ul>

        <div class="nav-actions" id="nav-actions">
          <!-- Avatar trigger for logged-in users (hidden by default) -->
          <div class="user-avatar" id="user-avatar-trigger" style="display:none;"></div>
          <!-- Dropdown menu (hidden initially) -->
          <div class="avatar-dropdown" id="avatar-dropdown" hidden>
            <div class="dropdown-header">
              <div class="avatar-large" id="avatar-large"></div>
              <div class="user-info">
                <div class="user-name" id="user-name"></div>
                <div class="user-email" id="user-email"></div>
              </div>
              <input type="file" accept="image/*" id="avatar-upload-input" hidden />
            </div>
            <ul class="dropdown-links">
              <li><a href="#" data-target="bookings">My 1-1 Bookings</a></li>
              <li><a href="#" data-target="vault">Document Vault</a></li>
              <li><a href="#" data-target="roadmap">My Action Roadmap</a></li>
              <hr />
              <li><a href="#" data-target="messages">Message Center</a></li>
              <li><a href="#" data-target="guides">My Saved Guides</a></li>
              <hr />
              <li><a href="#" id="guide-toggle-link">Switch to Guide View</a></li>
              <hr />
              <li><a href="#" data-target="profile">Edit Profile</a></li>
              <li><a href="#" data-target="settings">Account settings</a></li>
              <li><a href="#" data-target="billing">Payment methods</a></li>
              <hr />
              <li><a href="#" data-target="help">Help and Support</a></li>
              <li><a href="#" id="logout-link">Log out</a></li>
            </ul>
          </div>
          <!-- Sign In / Sign Up buttons for guests -->
          <button class="btn btn-outline" id="btn-signin">Sign In</button>
          <button class="btn btn-primary" id="btn-signup">Sign Up</button>
        </div>
    </div>
  </nav>

  <!-- PORTAL SUB-NAV CATEGORIES (EXPAT SUCCESS HUB) -->
  <div class="sub-nav-categories" id="portal-sub-nav" style="display: none; background: var(--bg-secondary); border-bottom: 1px solid var(--border-color); padding: 12px 0; box-shadow: var(--shadow-sm);">
    <div class="container" style="display: flex; gap: 16px; align-items: center; overflow-x: auto; white-space: nowrap;">
      <span style="font-size: 0.72rem; font-weight: 800; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em; margin-right: 12px;">Success Focus Areas:</span>
      <a href="#" class="sub-nav-cat active" data-focus="Status & Visas" style="color: var(--text-primary); text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 6px 16px; border-radius: 20px; transition: all 0.2s;">Status & Visas</a>
      <a href="#" class="sub-nav-cat" data-focus="Career & Jobs" style="color: var(--text-secondary); text-decoration: none; font-size: 0.85rem; font-weight: 500; padding: 6px 16px; border-radius: 20px; transition: all 0.2s;">Career & Jobs</a>
      <a href="#" class="sub-nav-cat" data-focus="Finance & Credit" style="color: var(--text-secondary); text-decoration: none; font-size: 0.85rem; font-weight: 500; padding: 6px 16px; border-radius: 20px; transition: all 0.2s;">Finance & Credit</a>
    </div>
  </div>

  <!-- HOME VIEW -->
  <section id="home" class="view-section active">
    <!-- Hero -->
    <header class="hero">
      <!-- Floating Images -->
      <img src="hero_candid_cafe.png" alt="Professional in cafe" class="hero-img hero-img-tl">
      <img src="hero_video_mentoring_1780945119982.png" alt="Mentoring laptop zoom call" class="hero-img hero-img-bl">
      <img src="hero_candid_document.png" alt="Professional with document" class="hero-img hero-img-tr">
      <img src="hero_candid_apartment.png" alt="Professional coding in apartment" class="hero-img hero-img-br">

      <div class="hero-content">
        <div class="badge">GET ADVICE FROM PEOPLE WHO HAVE WALKED YOUR PATH.</div>
        <h1 class="hero-title">Don't guess your way through.</h1>
        <p class="hero-subtitle">Connect with immigrants who have already solved the problems<br>you're facing right now.</p>
        
        <!-- Minimalist Hero Quiz Card (Simple Survey) -->
        <div class="hero-quiz-card">
          <!-- Top Nav Row: Back button + Step label -->
          <div class="quiz-top-nav">
            <button class="quiz-prev-btn" style="display: none;" aria-label="Go Back">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
              Back
            </button>
            <div class="quiz-progress-wrapper">
              <div class="quiz-progress-bar">
                <div class="quiz-progress-fill" id="hero-quiz-progress" style="width: 16.6%;"></div>
              </div>
              <span class="quiz-step-label">Step 1 of 3</span>
            </div>
          </div>

          <!-- Step 1: Focus Area -->
          <div class="quiz-step-slide active" data-step="1">
            <h3 class="quiz-step-title">What do you need help with?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-focus="status">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Status & Visas</span>
                  <span class="choice-row-desc">Get your visa approved, sort your paperwork, and navigate immigration.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-focus="career">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Career & Jobs</span>
                  <span class="choice-row-desc">Fix your resume, practice interviews, and negotiate a better salary.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-focus="finance">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Finance & Credit</span>
                  <span class="choice-row-desc">Build local credit, open bank accounts, and file local taxes.</span>
                </div>
              </button>
            </div>
          </div>

          <!-- FLOW A: STATUS & VISAS -->
          <!-- Step 2-status: Main Goal -->
          <div class="quiz-step-slide" data-step="2-status" style="display: none;">
            <h3 class="quiz-step-title">What is your main goal right now?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step2="visa">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Get or renew my visa</span>
                  <span class="choice-row-desc">Work visas, student visas, transfers, renewals.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step2="family">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Bring my family here</span>
                  <span class="choice-row-desc">Spousal sponsorship, dependent visas, family reunification.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step2="greencard">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Get my Green Card or Citizenship</span>
                  <span class="choice-row-desc">Permanent residency pathways, citizenship prep, naturalization.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 3-status: Guidance Choice -->
          <div class="quiz-step-slide" data-step="3-status" style="display: none;">
            <h3 class="quiz-step-title">How do you want to move forward?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step3="lawyer">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">I want to hire a vetted immigration lawyer</span>
                  <span class="choice-row-desc">Official legal advice from licensed attorneys.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="peer">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">I want advice from an immigrant who has already done this</span>
                  <span class="choice-row-desc">Practical, real-world guidance from a settled expat peer.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- FLOW B: CAREER & JOBS -->
          <!-- Step 2-career: Career Move -->
          <div class="quiz-step-slide" data-step="2-career" style="display: none;">
            <h3 class="quiz-step-title">What is your next career move?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step2="hired">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Get hired at a top company</span>
                  <span class="choice-row-desc">Expat job hunting, local interview prep, local resume tailoring.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step2="transfer">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Transfer my existing career</span>
                  <span class="choice-row-desc">Translating foreign degrees, professional re-certification, and bridging credential gaps.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step2="business">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Start my own business</span>
                  <span class="choice-row-desc">Founding a company, founder visa pathways, investment advice.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 3-career-hired: Industry Target -->
          <div class="quiz-step-slide" data-step="3-career-hired" style="display: none;">
            <h3 class="quiz-step-title">What industry are you targeting?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step3="tech">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Tech & Software</span>
                  <span class="choice-row-desc">Software engineers, designers, product managers, data.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="health">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Healthcare & Medicine</span>
                  <span class="choice-row-desc">Doctors, nurses, research, clinical, admin roles.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="engineering">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Engineering & Construction</span>
                  <span class="choice-row-desc">Civil, electrical, mechanical engineers, project leads.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="finance_biz">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Finance & Business</span>
                  <span class="choice-row-desc">Analysts, investment banking, consulting, marketing.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>
          <!-- Step 3-career-business: Founder Stage -->
          <div class="quiz-step-slide" data-step="3-career-business" style="display: none;">
            <h3 class="quiz-step-title">Where are you in the process?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step3="playbook">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">I have an idea, but I need a playbook</span>
                  <span class="choice-row-desc">Validation, market research, initial business planning.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="launch">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">I'm ready to launch and need legal/funding advice</span>
                  <span class="choice-row-desc">Company incorporation, funding options, legal setup.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 3-career-transfer: Credential Focus -->
          <div class="quiz-step-slide" data-step="3-career-transfer" style="display: none;">
            <h3 class="quiz-step-title">What is your primary credential concern?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step3="evaluation">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Degree Translation & Evaluation</span>
                  <span class="choice-row-desc">Credential recognition, course-by-course evaluations, and translations.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="licensing">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Professional Licensing & Certification</span>
                  <span class="choice-row-desc">Local board exams, state licensing, and compliance audits.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="bridging">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Bridging Credential Gaps</span>
                  <span class="choice-row-desc">Additional coursework, local exams, or training programs.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- FLOW C: FINANCE & CREDIT -->
          <!-- Step 2-finance: Hurdle -->
          <div class="quiz-step-slide" data-step="2-finance" style="display: none;">
            <h3 class="quiz-step-title">What is your biggest financial hurdle?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step2="credit">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Building a local credit score from zero</span>
                  <span class="choice-row-desc">Expat credit cards, credit history transfer, opening bank accounts.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step2="investing">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Buying a home or investing my money</span>
                  <span class="choice-row-desc">Mortgages for expats, investing, cross-border tax compliance.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 3-finance: Guidance Level -->
          <div class="quiz-step-slide" data-step="3-finance" style="display: none;">
            <h3 class="quiz-step-title">What kind of guidance do you need?</h3>
            <div class="quiz-choices-stack">
              <button class="quiz-choice-row" data-step3="basics">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">A step-by-step plan to set up my basics</span>
                  <span class="choice-row-desc">Opening expat accounts, transferring history, basic tax rules.</span>
                </div>
              </button>
              <button class="quiz-choice-row" data-step3="advanced">
                <div class="quiz-radio-indicator"></div>
                <div class="choice-row-text">
                  <span class="choice-row-title">Advanced strategies from a financial insider</span>
                  <span class="choice-row-desc">Expat investment advice, multi-state tax, mortgages, wealth management.</span>
                </div>
              </button>
            </div>
            <div class="quiz-actions-row">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 4: Rating Scale (Visa & Documentation) -->
          <div class="quiz-step-slide" data-step="4" style="display: none;">
            <span class="badge dynamic-badge" style="margin-bottom: 16px; background-color: rgba(200, 90, 90, 0.1); color: #c85a5a; font-weight: 700;">Vital Assessment</span>
            <h3 class="quiz-step-title dynamic-title" style="margin-bottom: 8px;">Visa & Documentation Readiness</h3>
            <p class="choice-row-desc dynamic-desc" style="margin-bottom: 24px;">How prepared are you with your visa and expat paperwork right now?</p>
            
            <div class="quiz-rating-container">
              <div class="rating-buttons-grid" data-theme="status" data-category="status">
                <button class="rating-btn" data-value="1">1</button>
                <button class="rating-btn" data-value="2">2</button>
                <button class="rating-btn" data-value="3">3</button>
                <button class="rating-btn" data-value="4">4</button>
                <button class="rating-btn" data-value="5">5</button>
                <button class="rating-btn" data-value="6">6</button>
                <button class="rating-btn" data-value="7">7</button>
                <button class="rating-btn" data-value="8">8</button>
                <button class="rating-btn" data-value="9">9</button>
                <button class="rating-btn" data-value="10">10</button>
              </div>
            </div>
            
            <!-- SVG motion goes here dynamically! -->
            <div class="visualizer-placeholder"></div>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center;">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 5: Rating Scale (Career & Job Market) -->
          <div class="quiz-step-slide" data-step="5" style="display: none;">
            <span class="badge dynamic-badge" style="margin-bottom: 16px; background-color: rgba(17, 47, 32, 0.1); color: var(--accent); font-weight: 700;">Vital Assessment</span>
            <h3 class="quiz-step-title dynamic-title" style="margin-bottom: 8px;">Career & Job Market Readiness</h3>
            <p class="choice-row-desc dynamic-desc" style="margin-bottom: 24px;">How confident are you about landing your target role locally?</p>
            
            <div class="quiz-rating-container">
              <div class="rating-buttons-grid" data-theme="career" data-category="career">
                <button class="rating-btn" data-value="1">1</button>
                <button class="rating-btn" data-value="2">2</button>
                <button class="rating-btn" data-value="3">3</button>
                <button class="rating-btn" data-value="4">4</button>
                <button class="rating-btn" data-value="5">5</button>
                <button class="rating-btn" data-value="6">6</button>
                <button class="rating-btn" data-value="7">7</button>
                <button class="rating-btn" data-value="8">8</button>
                <button class="rating-btn" data-value="9">9</button>
                <button class="rating-btn" data-value="10">10</button>
              </div>
            </div>
            
            <!-- SVG motion goes here dynamically! -->
            <div class="visualizer-placeholder"></div>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center;">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 6: Rating Scale (Finance & Credit) -->
          <div class="quiz-step-slide" data-step="6" style="display: none;">
            <span class="badge dynamic-badge" style="margin-bottom: 16px; background-color: rgba(245, 166, 35, 0.1); color: #f5a623; font-weight: 700;">Vital Assessment</span>
            <h3 class="quiz-step-title dynamic-title" style="margin-bottom: 8px;">Financial & Credit Readiness</h3>
            <p class="choice-row-desc dynamic-desc" style="margin-bottom: 24px;">How prepared are you with local credit, bank accounts, and tax rules?</p>
            
            <div class="quiz-rating-container">
              <div class="rating-buttons-grid" data-theme="finance" data-category="finance">
                <button class="rating-btn" data-value="1">1</button>
                <button class="rating-btn" data-value="2">2</button>
                <button class="rating-btn" data-value="3">3</button>
                <button class="rating-btn" data-value="4">4</button>
                <button class="rating-btn" data-value="5">5</button>
                <button class="rating-btn" data-value="6">6</button>
                <button class="rating-btn" data-value="7">7</button>
                <button class="rating-btn" data-value="8">8</button>
                <button class="rating-btn" data-value="9">9</button>
                <button class="rating-btn" data-value="10">10</button>
              </div>
            </div>
            
            <!-- SVG motion goes here dynamically! -->
            <div class="visualizer-placeholder"></div>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center;">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 7: Dynamic Multiple Choice (Target/Timeline) -->
          <div class="quiz-step-slide" data-step="7" style="display: none;">
            <span class="badge dynamic-badge" style="margin-bottom: 16px;">Timeline</span>
            <h3 class="quiz-step-title dynamic-title" style="margin-bottom: 8px;">Target Timeline</h3>
            <p class="choice-row-desc dynamic-desc" style="margin-bottom: 20px;">When do you need your goals completed?</p>
            
            <div class="quiz-choices-stack dynamic-choices-container">
              <!-- Choices dynamically generated in JS -->
            </div>
            
            <!-- SVG motion goes here dynamically! -->
            <div class="visualizer-placeholder"></div>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center;">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 8: Dynamic Multiple Choice (Blocker) -->
          <div class="quiz-step-slide" data-step="8" style="display: none;">
            <span class="badge dynamic-badge" style="margin-bottom: 16px;">Key Blocker</span>
            <h3 class="quiz-step-title dynamic-title" style="margin-bottom: 8px;">Key Blocker</h3>
            <p class="choice-row-desc dynamic-desc" style="margin-bottom: 20px;">What is your biggest roadblock?</p>
            
            <div class="quiz-choices-stack dynamic-choices-container">
              <!-- Choices dynamically generated in JS -->
            </div>
            
            <!-- SVG motion goes here dynamically! -->
            <div class="visualizer-placeholder"></div>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center;">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 9: Dynamic Choice (Goal Selection) -->
          <div class="quiz-step-slide" data-step="9" style="display: none;">
            <span class="badge dynamic-badge" style="margin-bottom: 16px;">Action Goals</span>
            <h3 class="quiz-step-title dynamic-title" style="margin-bottom: 8px;">Action Goals</h3>
            <p class="choice-row-desc dynamic-desc" style="margin-bottom: 20px;">What would it take to reach 10?</p>
            
            <div class="quiz-choices-stack dynamic-choices-container">
              <!-- Choices dynamically generated in JS -->
            </div>
            
            <!-- SVG motion goes here dynamically! -->
            <div class="visualizer-placeholder"></div>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center;">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 10: Dynamic Multiple Choice (Advisor Collaboration Style) -->
          <div class="quiz-step-slide" data-step="10" style="display: none;">
            <span class="badge dynamic-badge" style="margin-bottom: 16px;">Collaboration Style</span>
            <h3 class="quiz-step-title dynamic-title" style="margin-bottom: 8px;">Advisor Collaboration</h3>
            <p class="choice-row-desc dynamic-desc" style="margin-bottom: 20px;">How do you want to work with your advisor?</p>
            
            <div class="quiz-choices-stack dynamic-choices-container">
              <!-- Choices dynamically generated in JS -->
            </div>
            
            <!-- SVG motion goes here dynamically! -->
            <div class="visualizer-placeholder"></div>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center;">
              <button class="btn btn-text quiz-back-btn">Reset</button>
            </div>
          </div>

          <!-- Step 11: Sign Up / Sign In Slide -->
          <div class="quiz-step-slide" data-step="signup" style="display: none;">
            <span class="badge" style="margin-bottom: 16px; background-color: rgba(17, 47, 32, 0.1); color: var(--accent); font-weight: 700;">Secure Your Match</span>
            <h3 class="quiz-step-title" style="margin-bottom: 8px;">Save Your Expat Action Plan</h3>
            <p class="choice-row-desc" style="margin-bottom: 20px; font-size: 0.9rem; line-height: 1.5;">Create a free account to lock in your assessment results and connect with your matched advisor.</p>
            
            <form id="quiz-signup-form" style="width: 100%; display: flex; flex-direction: column; gap: 14px;">
              <!-- Toggle Tab Header -->
              <div class="auth-toggle-tab">
                <button type="button" class="auth-tab-btn active" id="btn-tab-signup">Sign Up</button>
                <button type="button" class="auth-tab-btn" id="btn-tab-login">Log In</button>
              </div>

              <!-- Form Inputs -->
              <div class="auth-input-group" id="group-fullname">
                <label for="auth-fullname">Full Name</label>
                <input type="text" id="auth-fullname" placeholder="Alex Johnson" />
              </div>
              
              <div class="auth-input-group">
                <label for="auth-email">Email Address</label>
                <input type="email" id="auth-email" placeholder="alex@example.com" required />
              </div>
              
              <div class="auth-input-group">
                <label for="auth-password">Password</label>
                <input type="password" id="auth-password" placeholder="••••••••" required />
              </div>
              
              <div id="auth-error-msg" style="color: #c85a5a; font-size: 0.82rem; font-weight: 500; display: none; text-align: left; margin-top: -4px;"></div>

              <button type="submit" class="btn btn-primary" id="btn-auth-submit" style="width: 100%; padding: 14px; margin-top: 6px; justify-content: center; display: flex; align-items: center; gap: 8px;">
                Create Account & View Match
              </button>
              
              <div class="auth-divider" style="display: flex; align-items: center; justify-content: center; margin: 10px 0; color: var(--text-secondary); font-size: 0.8rem; font-weight: 500; text-transform: uppercase;">
                <span style="flex-grow: 1; height: 1px; background-color: var(--border-color); margin-right: 12px;"></span>
                or
                <span style="flex-grow: 1; height: 1px; background-color: var(--border-color); margin-left: 12px;"></span>
              </div>
              
              <button type="button" class="btn btn-outline google-auth-btn" id="btn-google-quiz" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; padding: 12px; font-weight: 600; font-size: 0.9rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); cursor: pointer; transition: all 0.2s ease;">
                <svg width="18" height="18" viewBox="0 0 18 18">
                  <path fill="#EA4335" d="M9 3.58c1.02 0 1.94.35 2.66 1.04l2.02-2.02C12.46 1.41 10.87 1 9 1 5.48 1 2.5 3.02 1.04 5.96l2.87 2.22C4.59 5.37 6.57 3.58 9 3.58z"/>
                  <path fill="#4285F4" d="M17.64 9.2c0-.59-.05-1.17-.16-1.73H9v3.28h4.84c-.21 1.12-.84 2.07-1.79 2.7l2.78 2.16c1.63-1.5 2.57-3.7 2.57-6.41z"/>
                  <path fill="#FBBC05" d="M3.91 10.18c-.22-.66-.35-1.37-.35-2.1s.13-1.44.35-2.1L1.04 3.75C.37 5.09 0 6.6 0 8s.37 2.91 1.04 4.25l2.87-2.07z"/>
                  <path fill="#34A853" d="M9 17c2.43 0 4.47-.8 5.96-2.18l-2.79-2.15c-.78.52-1.78.83-3.17.83-2.43 0-4.41-1.79-5.14-4.2L1.04 12.2C2.5 15.13 5.48 17 9 17z"/>
                </svg>
                Continue with Google
              </button>
            </form>
            
            <div class="quiz-actions-row" style="margin-top: 24px; justify-content: center; border-top: 1px solid var(--border-color); padding-top: 16px;">
              <button class="btn btn-text quiz-back-btn">Reset Quiz</button>
            </div>
          </div>

          <!-- Shared Horizon Visualizer (Always at the bottom for Step 4, 5, 6) -->
          <div class="shared-horizon-visualizer" style="display: none;">
            <div class="rating-visual-wrapper">
              <div class="horizon-visual-container">
                <svg class="horizon-svg" viewBox="0 0 260 140" width="100%" height="100%">
                  <defs>
                    <linearGradient id="sky-gradient" x1="0%" y1="100%" x2="0%" y2="0%">
                      <stop offset="0%" stop-color="#f5efe6" />
                      <stop offset="100%" id="sky-glow-stop" stop-color="#eae2d5" />
                    </linearGradient>
                    <radialGradient id="sun-glow-grad" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#f5a623" stop-opacity="0.4" />
                      <stop offset="100%" stop-color="#f5a623" stop-opacity="0" />
                    </radialGradient>
                  </defs>
                  
                  <!-- Sky Background -->
                  <rect x="0" y="0" width="260" height="140" rx="16" fill="url(#sky-gradient)" />
                  
                  <!-- Sun Glow -->
                  <circle id="horizon-sun-glow" cx="210" cy="110" r="45" fill="url(#sun-glow-grad)" style="opacity: 0; transition: transform 0.5s ease, opacity 0.5s ease;" />
                  
                  <!-- Sun -->
                  <circle id="horizon-sun" cx="210" cy="110" r="16" fill="#f5a623" style="transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);" />
                  
                  <!-- Landscape / Hill Background -->
                  <path d="M 0 140 Q 130 140 260 90 L 260 140 Z" fill="#e8e2d5" />
                  <path d="M 0 140 Q 130 135 260 100 L 260 140 Z" fill="#112f20" opacity="0.08" />
                  <path d="M 0 140 Q 130 130 260 110 L 260 140 Z" fill="#112f20" opacity="0.12" />
                  
                  <!-- Path 1 (Status): y_base = 120 -->
                  <path d="M 25 120 Q 115 115 215 80" fill="none" stroke="rgba(200, 90, 90, 0.12)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="4,4" />
                  <path id="horizon-active-status" d="M 25 120 Q 115 115 215 80" fill="none" stroke="#c85a5a" stroke-width="3" stroke-linecap="round" stroke-dasharray="210" stroke-dashoffset="210" style="transition: stroke-dashoffset 0.6s cubic-bezier(0.16, 1, 0.3, 1);" />
                  
                  <!-- Path 2 (Career): y_base = 100 -->
                  <path d="M 25 100 Q 115 95 215 60" fill="none" stroke="rgba(17, 47, 32, 0.12)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="4,4" />
                  <path id="horizon-active-career" d="M 25 100 Q 115 95 215 60" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-dasharray="210" stroke-dashoffset="210" style="transition: stroke-dashoffset 0.6s cubic-bezier(0.16, 1, 0.3, 1);" />
                  
                  <!-- Path 3 (Finance): y_base = 80 -->
                  <path d="M 25 80 Q 115 75 215 40" fill="none" stroke="rgba(245, 166, 35, 0.12)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="4,4" />
                  <path id="horizon-active-finance" d="M 25 80 Q 115 75 215 40" fill="none" stroke="#f5a623" stroke-width="3" stroke-linecap="round" stroke-dasharray="210" stroke-dashoffset="210" style="transition: stroke-dashoffset 0.6s cubic-bezier(0.16, 1, 0.3, 1);" />
                  
                  <!-- Traveler 1: Status (Coral) -->
                  <g id="horizon-traveler-status" transform="translate(25, 120)" style="opacity: 0; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;">
                    <path d="M 0 -6 L 1.5 -1.5 L 6 0 L 1.5 1.5 L 0 6 L -1.5 1.5 L -6 0 L -1.5 -1.5 Z" fill="#c85a5a" />
                    <circle cx="0" cy="0" r="1.5" fill="#ffffff" />
                  </g>
                  
                  <!-- Traveler 2: Career (Green) -->
                  <g id="horizon-traveler-career" transform="translate(25, 100)" style="opacity: 0; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;">
                    <path d="M 0 -6 L 1.5 -1.5 L 6 0 L 1.5 1.5 L 0 6 L -1.5 1.5 L -6 0 L -1.5 -1.5 Z" fill="var(--accent)" />
                    <circle cx="0" cy="0" r="1.5" fill="#ffffff" />
                  </g>
                  
                  <!-- Traveler 3: Finance (Orange) -->
                  <g id="horizon-traveler-finance" transform="translate(25, 80)" style="opacity: 0; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;">
                    <path d="M 0 -6 L 1.5 -1.5 L 6 0 L 1.5 1.5 L 0 6 L -1.5 1.5 L -6 0 L -1.5 -1.5 Z" fill="#f5a623" />
                    <circle cx="0" cy="0" r="1.5" fill="#ffffff" />
                  </g>
                </svg>
              </div>
            </div>
            
            <!-- Visualizer Scoreboard Row -->
            <div class="visualizer-scores-row">
              <div class="score-pill status" id="score-pill-status">
                <span class="score-dot"></span>
                <span class="score-label">Status</span>
                <span class="score-val">-</span>
              </div>
              <div class="score-pill career" id="score-pill-career">
