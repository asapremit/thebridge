  <section id="stories" class="view-section">
    <div class="stories-container container" style="padding: 100px 24px 80px;">
      <div class="section-header center-align">
        <span class="badge">Success Stories</span>
        <h2 class="section-title">Real stories of resilience</h2>
        <p class="section-subtitle">Read how immigrants and expats found their path with the direct help of our verified advisors.</p>
        <p class="section-subtitle">These stories showcase real outcomes—career breakthroughs, visa approvals, financial stability—made possible through our advisors' expertise.</p>
      </div>

      <div class="stories-grid">
        <!-- Story 1 -->
        <div class="story-card">
          <span class="story-tag">Career Move</span>
          <p class="story-quote">"David's technical resume rebuild changed everything. Within three weeks of optimizing my profile for local tech ATS scanners, I landed four callbacks and signed my senior software engineer offer at a top-tier company."</p>
          <div class="story-author">
            <div class="story-author-details">
              <h4 class="author-name">Sofia R.</h4>
              <p class="author-bio">Senior Developer from Brazil • Guided by David K.</p>
            </div>
          </div>
        </div>

        <!-- Story 2 -->
        <div class="story-card">
          <span class="story-tag">Immigration Success</span>
          <p class="story-quote">"Sarah and Hassan walked me through my Green Card interview prep step-by-step. The mock interview prepared me for every single question the USCIS officer asked, and my petition was approved on the spot."</p>
          <div class="story-author">
            <div class="story-author-details">
              <h4 class="author-name">Mateo L.</h4>
              <p class="author-bio">Startup Founder from Argentina • Guided by Sarah J. & Hassan B.</p>
            </div>
          </div>
        </div>

        <!-- Story 3 -->
        <div class="story-card">
              <span class="story-tag">Financial Transition</span>
              <p class="story-quote">"Amanda helped me understand U.S. credit transfers and tax filings. Thanks to her financial roadmap, I established a secure score and successfully leased my first apartment within two months of arrival."</p>
              <div class="story-author">
                <div class="story-author-details">
                  <h4 class="author-name">Priya K.</h4>
                  <p class="author-bio">Medical Researcher from India • Guided by Amanda W.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ADVISOR APPLICATION VIEW -->
      <section id="application" class="view-section">
        <div class="application-container container" style="padding: 100px 24px 80px; max-width: 780px;">
          
          <!-- Header -->
          <div class="section-header center-align">
            <span class="badge">Join Our Network</span>
            <h2 class="section-title">Apply to become a guide</h2>
            <p class="section-subtitle">We're looking for people who have already navigated the system — and want to help others do the same. Fill out the form below and our team will review your application within 5 business days.</p>
          </div>

          <div class="form-wrapper">
            <form id="advisor-apply-form" class="apply-form">

              <!-- SECTION 1: Personal Info -->
              <div class="form-section-block">
                <h3 class="form-section-heading">01 — Personal Information</h3>

                <div class="form-group-row">
                  <div class="form-group">
                    <label for="apply-fname">First Name *</label>
                    <input type="text" id="apply-fname" placeholder="Maria" required>
                  </div>
                  <div class="form-group">
                    <label for="apply-lname">Last Name *</label>
                    <input type="text" id="apply-lname" placeholder="Gonzalez" required>
                  </div>
                </div>

                <div class="form-group-row">
                  <div class="form-group">
                    <label for="apply-email">Email Address *</label>
                    <input type="email" id="apply-email" placeholder="maria@example.com" required>
                  </div>
                  <div class="form-group">
                    <label for="apply-phone">Phone Number</label>
                    <input type="tel" id="apply-phone" placeholder="+1 (555) 000-0000">
                  </div>
                </div>

                <div class="form-group-row">
                  <div class="form-group">
                    <label for="apply-country-origin">Country of Origin *</label>
                    <input type="text" id="apply-country-origin" placeholder="Mexico" required>
                  </div>
                  <div class="form-group">
                    <label for="apply-country-current">Country You Currently Live In *</label>
                    <input type="text" id="apply-country-current" placeholder="United States" required>
                  </div>
                </div>

                <div class="form-group">
                  <label for="apply-city">City & State / Province *</label>
                  <input type="text" id="apply-city" placeholder="Houston, TX" required>
                </div>

                <div class="form-group">
                  <label for="apply-linkedin">LinkedIn Profile URL</label>
                  <input type="url" id="apply-linkedin" placeholder="https://linkedin.com/in/your-profile">
                </div>
              </div>

              <!-- SECTION 2: Your Journey -->
              <div class="form-section-block">
                <h3 class="form-section-heading">02 — Your Immigration Journey</h3>

                <div class="form-group">
                  <label for="apply-arrived">What year did you arrive in your current country? *</label>
                  <input type="number" id="apply-arrived" placeholder="2018" min="1960" max="2025" required>
                </div>

                <div class="form-group">
                  <label for="apply-visa-type">What visa or status category did you navigate? *</label>
                  <select id="apply-visa-type" required>
                    <option value="" disabled selected>Select the primary category</option>
                    <option value="work">Work Visa (H-1B, L-1, O-1, TN, etc.)</option>
                    <option value="student">Student Visa (F-1, J-1, M-1)</option>
                    <option value="family">Family-Based (Spouse, Parent, Sibling sponsorship)</option>
                    <option value="greencard">Permanent Residency / Green Card</option>
                    <option value="asylum">Asylum or Refugee</option>
                    <option value="citizenship">Naturalization / Citizenship</option>
                    <option value="eb">EB-1, EB-2, EB-3 Employment-Based</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="apply-journey">Describe your immigration journey in your own words *</label>
                  <textarea id="apply-journey" rows="5" placeholder="Share the key hurdles you faced — visa denials, RFEs, relocation challenges, rebuilding your career — and how you ultimately navigated them. Be as specific as possible." required></textarea>
                </div>

                <div class="form-group">
                  <label for="apply-biggest-win">What was your biggest win after arriving? *</label>
                  <textarea id="apply-biggest-win" rows="3" placeholder="e.g. Secured my first job in tech within 6 months, bought my first home, passed the bar exam in a new country..." required></textarea>
                </div>
              </div>

              <!-- SECTION 3: Expertise -->
              <div class="form-section-block">
                <h3 class="form-section-heading">03 — Your Area of Expertise</h3>

                <div class="form-group">
                  <label>Which service category best describes your expertise? * <span style="font-weight:400; font-size:0.8rem; color:var(--text-secondary)">(Select all that apply)</span></label>
                  <div class="checkbox-group">
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="status"> Immigration Status &amp; Visas</label>
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="career"> Career, Resume &amp; Job Search</label>
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="finance"> Finance, Banking &amp; Credit Building</label>
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="tax"> Tax Filing &amp; Expat Tax Planning</label>
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="wellness"> Mental Health &amp; Wellness</label>
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="housing"> Housing &amp; Lease Negotiation</label>
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="entrepreneurship"> Entrepreneurship &amp; Starting a Business</label>
                    <label class="checkbox-item"><input type="checkbox" name="specialty" value="education"> Education &amp; Credential Recognition</label>
                  </div>
                </div>

                <div class="form-group">
                  <label for="apply-credentials">Do you hold any professional licenses or certifications? *</label>
                  <select id="apply-credentials" required>
                    <option value="" disabled selected>Select one</option>
                    <option value="licensed">Yes — Licensed professional (Attorney, CPA, CFP, LCSW, etc.)</option>
                    <option value="certified">Yes — Certified specialist (PMP, SHRM, USCIS Accredited Rep, etc.)</option>
                    <option value="peer">No — I am a peer guide with lived experience</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="apply-credentials-detail">If licensed or certified, list your credentials</label>
                  <input type="text" id="apply-credentials-detail" placeholder="e.g. Licensed Immigration Attorney (TX Bar #12345), Enrolled Agent">
                </div>

                <div class="form-group">
                  <label for="apply-years">How many years have you been actively advising or mentoring others in this area? *</label>
                  <select id="apply-years" required>
                    <option value="" disabled selected>Select range</option>
                    <option value="0-1">Less than 1 year</option>
                    <option value="1-3">1–3 years</option>
                    <option value="3-5">3–5 years</option>
                    <option value="5-10">5–10 years</option>
                    <option value="10+">10+ years</option>
                  </select>
                </div>
              </div>

              <!-- SECTION 4: Your Approach -->
              <div class="form-section-block">
                <h3 class="form-section-heading">04 — Your Guiding Style</h3>

                <div class="form-group">
                  <label for="apply-approach">How would you describe your approach to advising someone new? *</label>
                  <textarea id="apply-approach" rows="4" placeholder="e.g. I lead with empathy and curiosity. I ask open-ended questions to understand where someone is, then share what worked for me and what I'd do differently. I never impose — I help people make decisions that fit their own values and goals." required></textarea>
                </div>

                <div class="form-group">
                  <label for="apply-first-session">What would your first session with a new client look like? *</label>
                  <textarea id="apply-first-session" rows="4" placeholder="e.g. We'd spend the first 15 minutes getting to know each other, then I'd walk through their current situation, top 3 blockers, and help them build a clear action plan for the next 30 days." required></textarea>
                </div>

                <div class="form-group">
                  <label for="apply-languages">Languages you can advise in *</label>
                  <input type="text" id="apply-languages" placeholder="e.g. English, Spanish, Portuguese" required>
                </div>

                <div class="form-group">
                  <label>Preferred session format *</label>
                  <div class="radio-group">
                    <label class="radio-item"><input type="radio" name="session-format" value="video" required> Video Call (Zoom, Google Meet)</label>
                    <label class="radio-item"><input type="radio" name="session-format" value="phone"> Phone Call</label>
                    <label class="radio-item"><input type="radio" name="session-format" value="both"> Both</label>
                  </div>
                </div>

                <div class="form-group">
                  <label>General availability *</label>
                  <div class="checkbox-group">
                    <label class="checkbox-item"><input type="checkbox" name="availability" value="weekday-am"> Weekday Mornings</label>
                    <label class="checkbox-item"><input type="checkbox" name="availability" value="weekday-pm"> Weekday Afternoons</label>
                    <label class="checkbox-item"><input type="checkbox" name="availability" value="weekday-eve"> Weekday Evenings</label>
                    <label class="checkbox-item"><input type="checkbox" name="availability" value="weekend"> Weekends</label>
                  </div>
                </div>
              </div>

              <!-- SECTION 5: Motivation -->
              <div class="form-section-block">
                <h3 class="form-section-heading">05 — Why same Path?</h3>

                <div class="form-group">
                  <label for="apply-why">Why do you want to guide others through their immigration journey? *</label>
                  <textarea id="apply-why" rows="4" placeholder="Share what drives you. What do you wish you had when you first arrived? Why does this work matter to you?" required></textarea>
                </div>

                <div class="form-group">
                  <label for="apply-referral">How did you hear about same Path?</label>
                  <select id="apply-referral">
                    <option value="" disabled selected>Select one</option>
                    <option value="social">Social media (Instagram, LinkedIn, Twitter)</option>
                    <option value="word">Word of mouth / referral</option>
                    <option value="search">Google / web search</option>
                    <option value="community">Community group or forum</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="apply-anything-else">Anything else you'd like us to know?</label>
                  <textarea id="apply-anything-else" rows="3" placeholder="Optional — share any additional context, a link to your work, or a question for our team."></textarea>
                </div>
              </div>

              <button type="submit" class="btn btn-primary btn-full apply-submit-btn" style="padding: 16px; font-size: 1rem; margin-top: 8px;">Submit My Application →</button>
              <p style="text-align:center; font-size:0.8rem; color:var(--text-secondary); margin-top:12px;">Our vetting team reviews every application personally. We'll follow up within 5 business days.</p>
            </form>

            <!-- Success Message -->
            <div id="apply-success-message" class="apply-success-card" style="display: none;">
              <div class="success-icon-wrap" style="margin: 0 auto 20px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3>Application Submitted!</h3>
              <p>Thank you for applying to join our network. Our vetting team will review your background and credentials personally, and we'll get back to you within 5 business days.</p>
              <button type="button" class="btn btn-primary" onclick="document.querySelector('.nav-link[data-target=\'home\']').click();" style="margin-top: 24px;">Return Home</button>
            </div>
          </div>
        </div>
      </section>

  <!-- Advisor Profile & Scheduler Modal -->
