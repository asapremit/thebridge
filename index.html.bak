              <div class="score-pill finance" id="score-pill-finance">
                <span class="score-dot"></span>
                <span class="score-label">Finance</span>
                <span class="score-val">-</span>
              </div>
            </div>
            
            <div class="rating-status-desc-box">
              <p id="rating-status-text">Select a number to rate your current progress.</p>
            </div>
          </div>
        </div>
      </div>
    </header>

